{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "dotenv -e ../../.env -- nest start --watch",
    "start": "nest start",
    "start:prod": "node dist/main",
    "lint": "eslint src/ --ext .ts",
    "test": "jest",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.22",
    "@mika/ai": "workspace:*",
    "@mika/database": "workspace:*",
    "@mika/shared": "workspace:*",
    "@nestjs/common": "^11.1.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.1",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/schedule": "^5.0.1",
    "@nestjs/terminus": "^11.0.0",
    "@prisma/client": "^6.9.0",
    "@types/express": "^5.0.6",
    "ai": "^4.3.16",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.53.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "grammy": "^1.36.1",
    "nestjs-pino": "^4.3.0",
    "nestjs-zod": "^4.3.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pino": "^9.6.0",
    "pino-http": "^10.5.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "@nestjs/cli": "^11.0.7",
    "@nestjs/schematics": "^11.0.5",
    "@nestjs/testing": "^11.1.1",
    "@types/bcrypt": "^5.0.2",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.15.21",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@mika/shared$": "<rootDir>/../../packages/shared/src/index.ts",
      "^@mika/database$": "<rootDir>/../../packages/database/src/index.ts",
      "^@mika/ai$": "<rootDir>/../../packages/ai/src/index.ts"
    }
  }
}
