{
  "testEnvironment": "node",
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@mika/shared$": "<rootDir>/../../packages/shared/src/index.ts",
    "^@mika/database$": "<rootDir>/../../packages/database/src/index.ts"
  }
}
