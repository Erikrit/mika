# Copie: cp docker/.env.staging.example .env.staging
# Hostinger sem domínio: use docker-compose.v1.5.yml para a VPS enxuta

# --- VPS Hostinger (sem domínio próprio) ---
VPS_HOST=srv1727136.hstgr.cloud
PUBLIC_WEB_URL=http://srv1727136.hstgr.cloud:3000
PUBLIC_API_URL=http://srv1727136.hstgr.cloud:3001
# Permite frontend local (pnpm dev) chamar a API remota
CORS_EXTRA_ORIGINS=http://localhost:3000

# --- Imagens (Docker Hub) ---
MIKA_API_IMAGE=mikaassit/mika-api:staging
MIKA_WEB_IMAGE=mikaassit/mika-web:staging
MIKA_WORKER_IMAGE=mikaassit/mika-worker:staging

# --- Domínio próprio (só quando usar docker-compose.staging.yml + Caddy) ---
# WEB_DOMAIN=web.staging.seudominio.com
# API_DOMAIN=api.staging.seudominio.com

# --- Postgres ---
POSTGRES_USER=mika
POSTGRES_PASSWORD=altere-senha-forte
POSTGRES_DB=mika
DATABASE_URL=postgresql://mika:altere-senha-forte@postgres:5432/mika

# --- Redis ---
REDIS_PASSWORD=altere-senha-forte

# --- Auth / criptografia (openssl rand -hex 32) ---
JWT_SECRET=
JWT_REFRESH_SECRET=
ENCRYPTION_KEY=

# --- IA (legado Telegram desligado por padrão) ---
OPENAI_API_KEY=sk-...

# --- Flags v1.5 enxuta ---
MIKA_TELEGRAM_MODULE_ENABLED=false
MIKA_REMINDERS_ENABLED=false
WORKER_MEMORY_INDEX_ENABLED=true
WORKER_REMINDER_DISPATCH_ENABLED=false
WORKER_NEGLECTED_JOBS_ENABLED=false
WORKER_NEGLECTED_GOALS_ENABLED=false
MEMORY_INDEX_CONCURRENCY=1
REMINDER_DISPATCH_CONCURRENCY=1

# --- Limites padrao Docker v1.5 ---
API_MEM_LIMIT=768m
WEB_MEM_LIMIT=512m
WORKER_MEM_LIMIT=512m
POSTGRES_MEM_LIMIT=1g
REDIS_MEM_LIMIT=192m
REDIS_MAXMEMORY=128mb
API_CPU_LIMIT=1.0
WEB_CPU_LIMIT=1.0
WORKER_CPU_LIMIT=1.0
POSTGRES_CPU_LIMIT=1.0
REDIS_CPU_LIMIT=0.5
DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=3

# --- Rotinas (disparo manual via curl/Swagger ou n8n legado — ver docker/README-LEGACY.md) ---
ROUTINE_API_KEY=

TZ=America/Sao_Paulo
LOG_LEVEL=warn
