{
  "name": "Mika — Health Check",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{ "field": "cronExpression", "expression": "*/5 * * * *" }]
        }
      },
      "id": "cron-health",
      "name": "Cron */5",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [240, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "http://host.docker.internal:3001/health"
      },
      "id": "http-health",
      "name": "GET /health",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [480, 300]
    }
  ],
  "connections": {
    "Cron */5": {
      "main": [[{ "node": "GET /health", "type": "main", "index": 0 }]]
    }
  },
  "settings": {
    "timezone": "America/Sao_Paulo"
  }
}
