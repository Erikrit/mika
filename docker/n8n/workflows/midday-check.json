{
  "name": "Mika — Check-in Meio-dia 12:30",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{ "field": "cronExpression", "expression": "30 12 * * *" }]
        }
      },
      "id": "cron-midday",
      "name": "Cron 12:30",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [240, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://host.docker.internal:3001/routines/midday-check",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "X-Routine-Key", "value": "={{ $env.ROUTINE_API_KEY }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={}"
      },
      "id": "http-midday",
      "name": "POST midday-check",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [480, 300]
    }
  ],
  "connections": {
    "Cron 12:30": {
      "main": [[{ "node": "POST midday-check", "type": "main", "index": 0 }]]
    }
  },
  "settings": {
    "timezone": "America/Sao_Paulo"
  }
}
