{
  "name": "mika",
  "version": "0.1.0",
  "private": true,
  "description": "Mika — Assistente Pessoal Inteligente",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "prisma:generate": "pnpm --filter @mika/database prisma:generate",
    "prisma:migrate": "pnpm --filter @mika/database prisma:migrate",
    "prisma:seed": "pnpm --filter @mika/database db:seed",
    "prisma:studio": "pnpm --filter @mika/database prisma:studio",
    "docker:build:api": "docker build -f docker/Dockerfile.api -t mikaassit/mika-api:staging .",
    "docker:build:web": "docker build -f docker/Dockerfile.web -t mikaassit/mika-web:staging .",
    "docker:build:worker": "docker build -f docker/Dockerfile.worker -t mikaassit/mika-worker:staging .",
    "docker:build:all": "pnpm docker:build:api && pnpm docker:build:web && pnpm docker:build:worker"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
