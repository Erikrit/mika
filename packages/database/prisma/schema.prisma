// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  P1
  P2
  P3
  P4
  P5
}

enum EnergyLevel {
  LOW
  MEDIUM
  HIGH
}

enum GoalHorizon {
  SHORT
  MEDIUM
  LONG
}

enum GoalStatus {
  ACTIVE
  ACHIEVED
  ABANDONED
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum EventSource {
  MANUAL
  GOOGLE
  TELEGRAM
}

enum RoutineType {
  MORNING
  MIDDAY
  EVENING
  FREE
}

enum FinanceGoalStatus {
  ACTIVE
  ACHIEVED
  PAUSED
}

enum ReminderChannel {
  TELEGRAM
  WEB_PUSH
  BOTH
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

enum ReminderEntityType {
  TASK
  EVENT
  GOAL
  CUSTOM
}

enum ChatChannel {
  WEB
  TELEGRAM
}

enum ChatRole {
  USER
  ASSISTANT
  SYSTEM
}

enum RoutineRunType {
  DAILY_SUMMARY
  WEEKLY_REVIEW
  MIDDAY_CHECK
  EVENING_REFLECTION
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  name           String
  passwordHash   String
  timezone       String   @default("America/Sao_Paulo")
  telegramChatId String?  @unique
  preferences    Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  lifeAreas    LifeArea[]
  tasks        Task[]
  projects     Project[]
  goals        Goal[]
  events       Event[]
  reflections  Reflection[]
  financeGoals FinanceGoal[]
  chatSessions ChatSession[]
  reminders    Reminder[]
  routineRuns  RoutineRun[]

  @@map("users")
}

model LifeArea {
  id     String  @id @default(uuid())
  userId String
  slug   String
  label  String
  color  String?
  icon   String?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks        Task[]
  projects     Project[]
  goals        Goal[]
  events       Event[]
  financeGoals FinanceGoal[]

  @@unique([userId, slug])
  @@map("life_areas")
}

model Project {
  id          String        @id @default(uuid())
  userId      String
  lifeAreaId  String
  title       String
  description String?
  status      ProjectStatus @default(ACTIVE)
  priority    Int           @default(3)
  startDate   DateTime?
  targetDate  DateTime?
  tags        String[]      @default([])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lifeArea LifeArea @relation(fields: [lifeAreaId], references: [id])
  tasks    Task[]

  @@index([userId, status])
  @@map("projects")
}

model Task {
  id             String      @id @default(uuid())
  userId         String
  projectId      String?
  lifeAreaId     String?
  parentTaskId   String?
  title          String
  description    String?
  status         TaskStatus  @default(TODO)
  priority       Int         @default(3)
  dueAt          DateTime?
  completedAt    DateTime?
  energyLevel    EnergyLevel?
  contextTags    String[]    @default([])
  neglectedSince DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  project    Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  lifeArea   LifeArea? @relation(fields: [lifeAreaId], references: [id], onDelete: SetNull)
  parentTask Task?     @relation("TaskSubtasks", fields: [parentTaskId], references: [id], onDelete: SetNull)
  subtasks   Task[]    @relation("TaskSubtasks")

  @@index([userId, status])
  @@index([userId, dueAt])
  @@map("tasks")
}

model Goal {
  id          String      @id @default(uuid())
  userId      String
  lifeAreaId  String
  title       String
  description String?
  horizon     GoalHorizon
  status      GoalStatus  @default(ACTIVE)
  targetDate  DateTime?
  progress    Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lifeArea LifeArea @relation(fields: [lifeAreaId], references: [id])

  @@index([userId, status])
  @@map("goals")
}

model Event {
  id          String      @id @default(uuid())
  userId      String
  lifeAreaId  String?
  title       String
  description String?
  startsAt    DateTime
  endsAt      DateTime?
  location    String?
  isAllDay    Boolean     @default(false)
  externalId  String?
  source      EventSource @default(MANUAL)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lifeArea LifeArea? @relation(fields: [lifeAreaId], references: [id], onDelete: SetNull)

  @@index([userId, startsAt])
  @@map("events")
}

model Reflection {
  id          String       @id @default(uuid())
  userId      String
  content     String
  energyLevel EnergyLevel?
  mood        String?
  routineType RoutineType?
  createdAt   DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("reflections")
}

model FinanceGoal {
  id            String            @id @default(uuid())
  userId        String
  lifeAreaId    String
  title         String
  targetAmount  String
  currentAmount String
  currency      String            @default("BRL")
  targetDate    DateTime?
  status        FinanceGoalStatus @default(ACTIVE)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lifeArea LifeArea @relation(fields: [lifeAreaId], references: [id])

  @@index([userId, status])
  @@map("finance_goals")
}

model ChatSession {
  id        String      @id @default(uuid())
  userId    String
  channel   ChatChannel
  title     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([userId, channel])
  @@map("chat_sessions")
}

model ChatMessage {
  id        String   @id @default(uuid())
  sessionId String
  role      ChatRole
  content   String
  metadata  Json?
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("chat_messages")
}

model Reminder {
  id          String             @id @default(uuid())
  userId      String
  entityType  ReminderEntityType
  entityId    String?
  message     String
  scheduledAt DateTime
  channel     ReminderChannel    @default(TELEGRAM)
  status      ReminderStatus     @default(PENDING)
  createdAt   DateTime           @default(now())

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  notificationLogs  NotificationLog[]

  @@index([scheduledAt, status])
  @@map("reminders")
}

model NotificationLog {
  id         String  @id @default(uuid())
  reminderId String
  channel    String
  status     String
  error      String?
  sentAt     DateTime @default(now())

  reminder Reminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)

  @@map("notification_logs")
}

model RoutineRun {
  id          String         @id @default(uuid())
  userId      String
  type        RoutineRunType
  content     String
  metadata    Json           @default("{}")
  deliveredAt DateTime?
  channel     ChatChannel    @default(TELEGRAM)
  createdAt   DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, createdAt])
  @@map("routine_runs")
}
